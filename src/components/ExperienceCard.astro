---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  image?: string;
  links?: { text: string; href: string }[];
}
const { title, subtitle, description, links = [], image } = Astro.props;
---

<div class="wrapper scroll-reveal">
  <div class="container">
    <div class="header">
      {
        image
          ? <img src={image} alt={title} />
          : <div class="default-icon">💼</div>
      }
      <div class="title">
        <h3>{title}</h3>
        <p>{subtitle}</p>
      </div>
    </div>

    <div class="details">
      <p>{description}</p>
    </div>

    {links.length > 0 && (
      <div class="footer">
        {links.map((link) => (
          <a href={link.href} target="_blank">{link.text}</a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .wrapper {
    border-left: 1px solid var(--border-color);
    position: relative;
    transition: border-color 0.3s ease;
  }

  .wrapper:hover {
    border-left-color: var(--primary);
  }

  .wrapper::before {
    content: "";
    position: absolute;
    left: 0;
    top: 16px;
    width: 12px;
    height: 12px;
    background: var(--primary);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  .wrapper:hover::before {
    background: var(--primary-light);
    box-shadow: 0 0 0 6px rgba(139, 92, 246, 0.15);
  }

  .container {
    padding: 1rem 2rem;
    border-radius: 0.8rem;
    max-width: 600px;
    margin-inline-start: 1.6rem;
    color: var(--color);
    padding-bottom: 40px;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .wrapper:hover .container {
    background: var(--card-bg);
    transform: translateX(4px);
  }

  .header {
    display: flex;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .header img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }

  .default-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: white;
  }

  .header .title {
    margin-inline-start: 0.8rem;
  }

  .header .title h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--color);
  }

  .header .title p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .details p {
    font-size: 0.9rem;
    margin: 0.5rem 0;
    color: var(--text-light);
  }

  .footer {
    margin-top: 0.5rem;
  }

  .footer a {
    color: var(--primary);
    text-decoration: none;
    margin-right: 1rem;
    font-size: 0.85rem;
    transition: opacity 0.25s ease, color 0.25s ease;
  }

  .footer a:hover {
    color: var(--primary-light);
    opacity: 0.9;
  }
</style>
